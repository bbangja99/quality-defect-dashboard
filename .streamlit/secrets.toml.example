# Streamlit secrets 예시.
# 실제 사용 시 이 파일을 'secrets.toml' 로 복사해 비밀번호를 채우세요.
# (secrets.toml 은 .gitignore 로 커밋 차단됨)
#
# - 로컬: webapp/.streamlit/secrets.toml 에 작성
# - Streamlit Cloud: 앱 Settings → Secrets 에 아래 내용 붙여넣기
#
# password 를 설정하면 앱 접속 시 비밀번호 게이트가 활성화됩니다.
# (비워두거나 키가 없으면 게이트 비활성)

password = "여기에-사내-공유용-비밀번호"
